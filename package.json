{
  "name": "netmeet-bot",
  "version": "1.0.0",
  "description": "NetMeet Bot - Resumo automático de reuniões Teams via Graph API + OpenAI (sem Azure Bot Framework)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:pilot": "node src/index.js",
    "start:user": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test:auth": "node src/test-auth.js",
    "test:email": "node src/test-email.js",
    "monitor": "node src/monitor.js",
    "dashboard": "node src/dashboard.js",
    "diagnose": "node src/diagnose.js",
    "force-summary": "node src/force-summary.js",
    "lint": "node scripts/check-js-syntax.js",
    "typecheck": "node scripts/check-js-syntax.js",
    "test": "node tests/run-tests.js"
  },
  "keywords": [
