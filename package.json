    "meetings",
    "summary",
    "openai",
    "graph-api"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "nodemailer": "^6.9.0"
  }
