# ============================================================
# NetMeet Bot - Exemplo de Configuração
# ============================================================
# Copie este arquivo para .env e preencha os valores

# --- MICROSOFT ENTRA ID (Azure AD) ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# --- GOOGLE GEMINI ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- GROQ FALLBACK ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OPENROUTER FALLBACK ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# --- EMAIL SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=NetMeet Bot

# --- SERVIDOR ---
PORT=3000
# Para piloto com varios usuarios, troque localhost pelo IP/nome do servidor
# onde o dashboard ficara rodando. Ex.: http://192.168.0.10:3000
DASHBOARD_URL=http://localhost:3000

# --- MONITORAMENTO ---
CHECK_INTERVAL_MINUTES=5
# Aguarda esse tempo apos o fim agendado antes de tentar gerar o resumo.
# Isso evita resumo prematuro quando a reuniao passa do horario ou quando
# o Teams ainda nao terminou de processar a transcricao.
POST_MEETING_WAIT_MINUTES=60
# Janela padrao do lembrete preventivo: 30 minutos antes da reuniao.
# Captura reunioes que ja comecaram dentro desta janela, caso o monitor
# tenha iniciado depois do horario de inicio.
ACTIVE_MEETING_LOOKBACK_MINUTES=60
ENDED_MEETING_LOOKBACK_HOURS=8
# Pausa novas tentativas da mesma reuniao quando a IA retorna cota/429.
SUMMARY_FAILURE_COOLDOWN_MINUTES=240

# --- PILOTO ---
# Separe emails por virgula, ponto e virgula ou espaco.
# Quando preenchido, npm start processa somente estes usuarios.
PILOT_USERS=alan.moreira@netturbo.com.br,usuario2@netturbo.com.br

# --- LOG ---
LOG_LEVEL=info
